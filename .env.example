# ─────────────────────────────────────────────────────────────────────────────
#  LeadScope — Environment Configuration
#  Copy this file to .env and fill in values as needed.
#
#  ✅ API KEYS ARE OPTIONAL — DuckDuckGo search is used by default (free).
#     Only set keys below if you want a higher search quota or Google results.
# ─────────────────────────────────────────────────────────────────────────────

# Option A — SerpAPI (100 free searches/month after signup at serpapi.com)
SERPAPI_KEY=

# Option B — Google Custom Search Engine
# Get key at: https://console.cloud.google.com → Custom Search JSON API
# Get CX at:  https://programmablesearchengine.google.com
GCSE_API_KEY=
GCSE_CX=

# ─── Optional settings ───────────────────────────────────────────────────────

# Country code for phone-number parsing (ISO 3166-1 alpha-2)
DEFAULT_PHONE_REGION=IN

# SQLite path (relative to project root)
DB_PATH=leads.db
